{
  "scripts": {
    "dev": "sh -c 'trap \"kill 0\" EXIT; npm run dev:backend & npm run dev:frontend & wait'",
    "dev:backend": "JAVA_TOOL_OPTIONS='--enable-native-access=ALL-UNNAMED' uvicorn backend.main:app --reload",
    "dev:frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8"
  }
}
